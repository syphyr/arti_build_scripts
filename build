sudo update-alternatives --set gcc /usr/bin/gcc-8
sudo update-alternatives --set g++ /usr/bin/g++-8
sudo update-alternatives --set cpp /usr/bin/cpp-8

gcc --version
g++ --version
cpp --version

if ! command -v rustup >/dev/null 2>&1; then
  echo "Error: rustup is not installed. Please install before running this script."
  echo ""
  echo "To install rust if needed:"
  echo "curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh"
  exit 1
fi

export PKG_CONFIG_PATH="$(pwd)/build_libs/lib/pkgconfig"

export OPENSSL_DIR="$(pwd)/build_libs"
export OPENSSL_LIB_DIR="$(pwd)/build_libs/lib"
export OPENSSL_INCLUDE_DIR="$(pwd)/build_libs/include"

export SQLITE3_DIR="$(pwd)/build_libs"
export SQLITE3_LIB_DIR="$(pwd)/build_libs/lib"
export SQLITE3_INCLUDE_DIR="$(pwd)/build_libs/include"

make -f build-libs

cd arti
./build-debian.sh

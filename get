if [ ! -d arti ]; then
   git clone https://gitlab.torproject.org/tpo/core/arti.git
fi

cd arti
git fetch
git log --pretty="%C(yellow)%h %C(green)(%cr) %C(red)(%ar) %C(white)%s %C(blue)(%an)" -10 origin/main
git rebase

APPLIED=$(git log --oneline --grep="debian: Auto generate changelog")
if [ "$APPLIED" == "" ]; then
	git am ../patches/0001-debian-Auto-generate-changelog.patch
else
	echo "debian: Auto generate changelog already applied"
fi

APPLIED=$(git log --oneline --grep="debian: Support flag for static build")
if [ "$APPLIED" == "" ]; then
        git am ../patches/0002-debian-Support-flag-for-static-build.patch
else
        echo "debian: Support flag for static build already applied"
fi
